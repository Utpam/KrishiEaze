{
  "info": {
    "name": "KrishiEaze API",
    "description": "Postman collection for KrishiEaze Spring Boot Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"mobileNo\": \"1234567890\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/signup-request",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "signup-request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"mobileNo\": \"1234567890\",\r\n  \"otp\": \"123456\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/verify-otp",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "verify-otp"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/auth/refresh",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstName\": \"John\",\r\n  \"middleName\": \"A\",\r\n  \"surName\": \"Doe\",\r\n  \"address\": \"123 Farm Lane\",\r\n  \"state\": \"Maharashtra\",\r\n  \"district\": \"Pune\",\r\n  \"pinCode\": \"123456\",\r\n  \"roles\": [\"FARMER\"]\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/profile/update",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "profile",
                "update"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/profile/me",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "profile",
                "me"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Location",
      "item": [
        {
          "name": "Update Location",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"lat\": 18.5204,\r\n  \"lng\": 73.8567\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/location/update-location",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "location",
                "update-location"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Mandi",
      "item": [
        {
          "name": "Get Nearest Mandis",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/mandi/nearest?crop={{crop}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "mandi",
                "nearest"
              ],
              "query": [
                {
                  "key": "crop",
                  "value": "{{crop}}",
                  "description": "Crop name entered by farmer (e.g. Wheat, Tomato, Onion)"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sell Request (Farmer)",
      "item": [
        {
          "name": "Create Sell Request",
          "description": "Farmer clicks Sell Request button on a mandi block. lat/lng is automatically taken from farmer profile - no need to send it manually.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"selectedMandiId\": 9,\r\n  \"cropName\": \"Tomato\",\r\n  \"quantity\": 1200,\r\n  \"unit\": \"kg\",\r\n  \"expectedPricePerUnit\": 18.50,\r\n  \"harvestDate\": \"2026-04-18\",\r\n  \"qualityGrade\": \"A\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/mandi/sell-request",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "mandi",
                "sell-request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get My Sell Requests",
          "description": "Farmer views all their own sell requests sorted by latest first.",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/mandi/sell-request/my-requests",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "mandi",
                "sell-request",
                "my-requests"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "your_jwt_token_here",
      "type": "string",
      "description": "JWT access token obtained after OTP verification"
    },
    {
      "key": "crop",
      "value": "Tomato",
      "type": "string",
      "description": "Crop name to search for in nearby mandis (e.g. Tomato, Wheat, Onion)"
    }
  ]
}
