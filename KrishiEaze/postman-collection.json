{
  "info": {
    "name": "KrishiEaze API",
    "description": "Postman collection for KrishiEaze Spring Boot Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"mobileNo\": \"1234567890\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/signup-request",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "signup-request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"mobileNo\": \"1234567890\",\r\n  \"otp\": \"123456\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/verify-otp",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "verify-otp"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/auth/refresh",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstName\": \"John\",\r\n  \"middleName\": \"A\",\r\n  \"surName\": \"Doe\",\r\n  \"address\": \"123 Farm Lane\",\r\n  \"state\": \"Maharashtra\",\r\n  \"district\": \"Pune\",\r\n  \"pinCode\": \"123456\",\r\n  \"roles\": [\"FARMER\"]\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/profile/update",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "profile",
                "update"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/profile/me",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "profile",
                "me"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Location",
      "item": [
        {
          "name": "Update Location",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"lat\": 18.5204,\r\n  \"lng\": 73.8567\r\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/location/update-location",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "location",
                "update-location"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ]
}
